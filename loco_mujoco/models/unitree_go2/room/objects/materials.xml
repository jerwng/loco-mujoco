<mujoco>
  <material name="mat_wall" rgba="0.85 0.85 0.85 1"/>
  <include file="materials_chair.xml"/>

  <include file="materials_table.xml"/>

  <include file="materials_bookshelf.xml"/>
  <material name="mat_book_red" rgba="0.70 0.18 0.16 1"/>
  <material name="mat_book_blue" rgba="0.16 0.31 0.62 1"/>
  <material name="mat_book_green" rgba="0.22 0.45 0.24 1"/>
  <material name="mat_book_yellow" rgba="0.78 0.66 0.22 1"/>
  <material name="mat_book_dark" rgba="0.20 0.18 0.17 1"/>

  <include file="materials_couch.xml"/>
  <include file="materials_cardboard.xml"/>

  <texture name="tex_metal" type="2d" file="metal.png"/>
  <material name="mat_metal" texture="tex_metal" texrepeat="2 2" reflectance="0.3"/>
  <material name="mat_trash_can_dark_green"
            texture="tex_metal"
            texrepeat="2 2"
            rgba="0.10 0.18 0.12 1"
            specular="0.18"
            shininess="0.20"
            reflectance="0.02"/>

  <texture name="tex_floor" type="2d" builtin="checker" width="512" height="512"
           rgb1="0.55 0.55 0.55" rgb2="0.50 0.50 0.50"/>
  <material name="mat_floor" texture="tex_floor" texrepeat="4 4" reflectance="0.00"/>

</mujoco>
